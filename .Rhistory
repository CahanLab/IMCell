nets1_3<-utils_loadObject("~/Desktop/LabThings/CompForce/analysis_dynamicCFE/20221104_dynamicCFE/dynCFE_simres_margperc20_nets01_03_classification_20221108.rda")
nets4_5<-utils_loadObject("~/Desktop/LabThings/CompForce/analysis_dynamicCFE/20221104_dynamicCFE/dynCFE_simres_margperc20_nets04_05_classification_20221108.rda")
nets11_13<-utils_loadObject("~/Desktop/LabThings/CompForce/analysis_dynamicCFE/20221104_dynamicCFE/dynCFE_simres_margperc20_nets11_13_classification_20221108.rda")
nets14<-utils_loadObject("~/Desktop/LabThings/CompForce/analysis_dynamicCFE/20221104_dynamicCFE/dynCFE_simres_margperc20_nets14_classification_20221108.rda")
nets15<-utils_loadObject("~/Desktop/LabThings/CompForce/analysis_dynamicCFE/20221104_dynamicCFE/dynCFE_simres_margperc20_nets15_classification_20221108.rda")
classres<-rbind(nets1_3,nets4_5)
classres<-rbind(classres,nets11_13)
classres<-rbind(classres,nets14)
classres<-rbind(classres,nets15)
agg_df<-aggregate(.~model+source+target,classres,mean)
agg_df<-melt(agg_df,id.vars=c("model","source","target"))
# PRIM results
primres<-utils_loadObject("~/Desktop/LabThings/CompForce/analysis_IM/20221007_PRIM_test/simulation_results/dfs_for_plotting/primDF_margperc20_aggregatedmean_20221122.rda")
primres<-primres[primres$method=="PRIM",]
primres$method<-NULL
# combine and plot
agg_df$method<-"dynIMCell"
primres$method<-"IMCell"
combined<-rbind(agg_df,primres)
combined$variable<-as.character(combined$variable)
combined$variable[combined$variable=="source_class_score"]<-"source"
combined$variable[combined$variable=="target_class_score"]<-"target"
combined$variable[combined$variable=="other_class_score"]<-"other"
combined$variable<-factor(combined$variable,levels=c("source","target","other"))
g1<-ggplot(combined,aes(x=variable,y=value,fill=method))+geom_boxplot(outlier.size = 0.3)+theme_minimal()+ theme(axis.title.x = element_blank(),axis.text.x = element_text(size=8),axis.title.y=element_text(size=8),axis.text.y=element_text(size=7),legend.position="right",legend.title=element_blank(),legend.text=element_text(size=7),strip.text=element_text(size=8),legend.margin=ggplot2::margin(0,0,0,0),legend.box="vertical",legend.spacing.y=unit(0.005,'cm'),strip.background=element_rect(colour="white",fill="white")) + scale_fill_brewer(palette="Paired",direction=-1)  + ylab("Classification Score")
print(g1)
combined$model_type<-"simple"
combined$model_type[combined$model %in% c("net11","net12","net13","net14","net15")]<-"complex"
combined$model_type<-factor(combined$model_type,levels=c("simple","complex"))
g2<-ggplot(combined,aes(x=variable,y=value,fill=method))+geom_boxplot(outlier.size = 0.3)+facet_wrap(~model_type)+theme_bw()+ theme(axis.title.x = element_blank(),axis.text.x = element_text(size=8),axis.title.y=element_text(size=8),axis.text.y=element_text(size=7),legend.position="right",legend.title=element_blank(),legend.text=element_text(size=7),strip.text=element_text(size=8),legend.margin=ggplot2::margin(0,0,0,0),legend.box="vertical",legend.spacing.y=unit(0.005,'cm'),strip.background=element_rect(colour="white",fill="white")) + scale_fill_brewer(palette="Paired",direction=-1) + scale_color_brewer(palette="Set3") + ylab("Classification Score")
print(g2)
